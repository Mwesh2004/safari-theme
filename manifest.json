{
  "manifest_version": 3,
  "name": "Safari Theme",
  "version": "1.0",
  "icons": {
    "128": "icon128.png"
  },
  "theme": {
    "images": {
      "theme_frame": "images/frame.png",
      "theme_ntp_background": "images/background.png",
      "theme_frame_inactive": "images/frame.png",
      "theme_tab_background": "images/frame.png"
    },
    "colors": {
      "frame": [20, 20, 22],
      "frame_inactive": [25, 25, 27],
      "toolbar": [42, 42, 44],
      "tab_text": [255, 255, 255],
      "tab_background_text": [200, 200, 200],
      "bookmark_text": [255, 255, 255],
      "ntp_background": [28, 28, 30],
      "ntp_text": [255, 255, 255],
      "ntp_link": [0, 122, 255],
      "ntp_header": [30, 30, 32],
      "control_background": [42, 42, 44]
    },
    "tints": {
      "buttons": [0.25, 0.5, 0.75],
      "background_tab": [0.25, 0.45, 0.35],
      "frame": [0.25, 0.5, 0.6]
    },
    "properties": {
      "ntp_background_alignment": "center",
      "ntp_background_repeat": "no-repeat",
      "ntp_logo_alternate": 1
    }
  }
}